{
  "name": "vs-aedifex",
  "displayName": "Aedifex for VS Code",
  "description": "Official Visual Studio Code support for Aedifex projects.",
  "version": "1.0.6",
  "publisher": "dimensionscape",
  "icon": "icon.png",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/dimensionscapeorg/aedifex.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionDependencies": [
    "nadako.vshaxe"
  ],
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:haxe",
    "workspaceContains:Aedifex.hx",
    "onDebugInitialConfigurations",
    "onDebugResolve:aedifex"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aedifex.selectTarget",
        "title": "Aedifex: Select Target"
      },
      {
        "command": "aedifex.selectProfile",
        "title": "Aedifex: Select Profile"
      },
      {
        "command": "aedifex.build",
        "title": "Aedifex: Build"
      },
      {
        "command": "aedifex.clean",
        "title": "Aedifex: Clean"
      },
      {
        "command": "aedifex.run",
        "title": "Aedifex: Run"
      },
      {
        "command": "aedifex.debug",
        "title": "Aedifex: Debug"
      },
      {
        "command": "aedifex.rebuild",
        "title": "Aedifex: Rebuild Tool"
      },
      {
        "command": "aedifex.task",
        "title": "Aedifex: Run Task"
      },
      {
        "command": "aedifex.refresh",
        "title": "Aedifex: Refresh Project State"
      }
    ],
    "configuration": {
      "title": "Aedifex",
      "properties": {
        "aedifex.cliPath": {
          "type": "string",
          "default": "",
          "description": "Optional path or command for the Aedifex CLI, such as `aedifex`, `aedifex.cmd`, or `run.n`."
        },
        "aedifex.pluginsPath": {
          "type": "string",
          "default": "",
          "description": "Optional plugin directory passed to the Aedifex CLI via -plugins."
        },
        "aedifex.theme": {
          "type": "string",
          "default": "",
          "description": "Optional Aedifex banner theme passed to interactive CLI commands via -theme."
        }
      }
    },
    "debuggers": [
      {
        "type": "aedifex",
        "label": "Aedifex",
        "languages": [
          "haxe"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "type",
              "request",
              "name"
            ],
            "properties": {
              "target": {
                "type": "string",
                "description": "Optional target override for this debug launch."
              },
              "targetLabel": {
                "type": "string",
                "description": "Optional display label for a plugin-provided target entry."
              },
              "targetSource": {
                "type": "string",
                "description": "Optional target provider identifier such as `aedifex` or `plugin`."
              },
              "platform": {
                "type": "string",
                "description": "Optional platform qualifier passed through to Aedifex."
              },
              "architecture": {
                "type": "string",
                "description": "Optional architecture qualifier passed through to Aedifex."
              },
              "profile": {
                "type": "string",
                "description": "Optional profile override for this debug launch."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "aedifex",
            "request": "launch",
            "name": "Aedifex"
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "aedifex",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "The Aedifex command to execute."
          },
          "target": {
            "type": "string",
            "description": "The active Aedifex target."
          },
          "targetLabel": {
            "type": "string",
            "description": "Optional display label for a plugin-provided target entry."
          },
          "targetSource": {
            "type": "string",
            "description": "Optional target provider identifier such as `aedifex` or `plugin`."
          },
          "platform": {
            "type": "string",
            "description": "Optional platform qualifier passed through to Aedifex."
          },
          "architecture": {
            "type": "string",
            "description": "Optional architecture qualifier passed through to Aedifex."
          },
          "profile": {
            "type": "string",
            "description": "The active Aedifex profile."
          },
          "clean": {
            "type": "boolean",
            "description": "Whether the build should run with -clean."
          }
        }
      }
    ]
  },
  "scripts": {
    "lint": "echo No lint configured"
  }
}



